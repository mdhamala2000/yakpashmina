{
  "name": "@airwallex/airtracker",
  "version": "3.2.0",
  "scripts": {
    "clean": "rm -rf ./lib",
    "size": "size-limit",
    "build": "tsup",
    "build-old": "yarn clean & tsc",
    "prepack": "yarn build",
    "lint": "eslint --fix 'src/**/*.ts'",
    "test": "jest",
    "sonar": "sonar-scanner"
  },
  "publishConfig": {
    "access": "public"
  },
  "description": "Integrated and secure solution of client side log",
  "author": "Luke Lu <luke.chenyang.lu@airwallex.com>",
  "license": "ISC",
  "main": "lib/index.js",
  "module": "lib/index.mjs",
  "types": "lib/index.d.ts",
  "files": [
    "lib/**/*"
  ],
  "devDependencies": {
    "@babel/cli": "^7.19.3",
    "@babel/core": "^7.20.2",
    "@babel/preset-env": "^7.20.2",
    "@semantic-release/changelog": "^6.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/gitlab": "^9.5.0",
    "@size-limit/esbuild": "^11.2.0",
    "@size-limit/file": "^11.2.0",
    "@swc/core": "^1.10.1",
    "@types/jest": "^29.2.3",
    "@types/node": "^18.11.9",
    "@typescript-eslint/eslint-plugin": "^5.43.0",
    "@typescript-eslint/parser": "^5.43.0",
    "eslint": "^8.27.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.3.1",
    "jest-environment-jsdom": "^29.3.1",
    "prettier": "^2.7.1",
    "semantic-release": "^19.0.5",
    "size-limit": "^11.2.0",
    "ts-jest": "^29.0.3",
    "tslib": "^2.4.1",
    "tsup": "^8.0.2",
    "typescript": "^4.8.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "globals": {
      "ts-jest": {
        "tsconfig": "tsconfig.json"
      }
    },
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/*.test.ts"
    ]
  },
  "prettier": {
    "printWidth": 120,
    "singleQuote": true,
    "trailingComma": "all"
  },
  "size-limit": [
    {
      "path": "lib/index.js"
    }
  ],
  "tsup": {
    "entryPoints": [
      "src/index.ts"
    ],
    "outDir": "lib",
    "format": [
      "cjs",
      "esm"
    ],
    "target": "es5",
    "platform": "browser",
    "dts": true
  }
}
